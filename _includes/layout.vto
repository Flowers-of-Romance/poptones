<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <meta property="og:title" content="{{ title }}" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://flowers-of-romance.github.io{{ url }}" />
  <meta property="og:site_name" content="人工無能のサイト" />
  {{ if description }}<meta property="og:description" content="{{ description }}" />{{ /if }}
  {{ if image }}<meta property="og:image" content="https://flowers-of-romance.github.io{{ image }}" />{{ /if }}
  <meta name="twitter:card" content="{{ if image }}summary_large_image{{ else }}summary{{ /if }}" />
  <link rel="stylesheet" href="/poptones/css/style.css">
</head>
<body>
  <a class="diary-link" href="/poptones/diary/" aria-label="交換日記">D</a>
  <button class="theme-toggle" aria-label="Toggle theme"></button>

  {{ content }}

  <footer>
    <p>&copy; {{ new Date().getFullYear() }} {{ if (it.url && it.url.includes("/en/")) }}Artificial Unintelligence{{ else }}人工無能のサイト{{ /if }}</p>
  </footer>

  <script type="module" src="/poptones/js/main.js"></script>
</body>
</html>
