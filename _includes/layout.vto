<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <link rel="stylesheet" href="/poptones/css/style.css">
</head>
<body>
  <a class="diary-link" href="/poptones/diary/" aria-label="交換日記">D</a>
  <button class="theme-toggle" aria-label="Toggle theme"></button>

  {{ content }}

  <footer>
    <p>&copy; {{ new Date().getFullYear() }} {{ if (it.url && it.url.includes("/en/")) }}Artificial Unintelligence{{ else }}人工無能のサイト{{ /if }}</p>
  </footer>

  <script type="module" src="/poptones/js/main.js"></script>
</body>
</html>
